# Copy these keys into Render → Environment tab
# DO NOT commit real values — fill them in the Render dashboard

NODE_ENV=production
PORT=10000
MONGODB_URI=<your-mongodb-atlas-uri>
JWT_SECRET=<your-strong-jwt-secret>
JWT_EXPIRATION=24h
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=https://fit-nova.web.app,https://fit-nova.firebaseapp.com
